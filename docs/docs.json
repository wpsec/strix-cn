{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Strix",
  "colors": {
    "primary": "#000000",
    "light": "#ffffff",
    "dark": "#000000"
  },
  "favicon": "/images/favicon-48.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "文档",
        "groups": [
          {
            "group": "开始使用",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "使用说明",
            "pages": [
              "usage/cli",
              "usage/scan-modes",
              "usage/instructions"
            ]
          },
          {
            "group": "模型与兼容",
            "pages": [
              "llm-providers/overview",
              "llm-providers/openai",
              "llm-providers/anthropic",
              "llm-providers/openrouter",
              "llm-providers/vertex",
              "llm-providers/bedrock",
              "llm-providers/azure",
              "llm-providers/novita",
              "llm-providers/local"
            ]
          },
          {
            "group": "集成",
            "pages": [
              "integrations/github-actions",
              "integrations/ci-cd"
            ]
          },
          {
            "group": "工具",
            "pages": [
              "tools/overview",
              "tools/browser",
              "tools/proxy",
              "tools/terminal",
              "tools/sandbox"
            ]
          },
          {
            "group": "高级",
            "pages": [
              "advanced/configuration",
              "advanced/skills",
              "contributing"
            ]
          }
        ]
      },
      {
        "tab": "云平台",
        "groups": [
          {
            "group": "Strix Cloud",
            "pages": [
              "cloud/overview"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/usestrix/strix",
          "icon": "github"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/strix-ai",
          "icon": "discord"
        }
      ]
    }
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "试用 Strix Cloud",
      "href": "https://app.strix.ai"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/strix_ai",
      "github": "https://github.com/usestrix",
      "discord": "https://discord.gg/strix-ai"
    }
  },
  "fonts": {
    "family": "Geist",
    "heading": {
      "family": "Geist"
    },
    "body": {
      "family": "Geist"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "description": "面向中文用户持续维护的 AI 安全代理分支",
  "background": {
    "decoration": "grid"
  }
}
